diff --git a/can_uart_bridge/boards/qemu_cortex_m3.overlay b/can_uart_bridge/boards/qemu_cortex_m3.overlay
new file mode 100644
index 0000000..13eddf8
--- /dev/null
+++ b/can_uart_bridge/boards/qemu_cortex_m3.overlay
@@ -0,0 +1,26 @@
+/*
+ * SPDX-FileCopyrightText: Copyright (c) 2026 Jilay Sandeep Pandya
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+/ {
+	chosen {
+		zephyr,canbus   = &can_loopback0;
+		zephyr,uart-can = &uart_emul;
+	};
+
+	can_loopback0: can_loopback0 {
+		compatible = "zephyr,can-loopback";
+		status = "okay";
+		bitrate = <500000>;
+	};
+
+	uart_emul: uart-emul {
+		compatible = "zephyr,uart-emul";
+		status = "okay";
+		current-speed = <115200>;
+		rx-fifo-size = <256>;
+		tx-fifo-size = <256>;
+		loopback;
+	};
+};
